import { Button, Slider, AboutSlint, LineEdit } from "std-widgets.slint";

export struct SegmentData {
    x1: float, y1: float,
    x2: float, y2: float,
    x3: float, y3: float,
    x4: float, y4: float,
    radius: float,
    sweep: bool,
}

export struct LeafData {
    px: float, py: float,
    bx: float, by: float,
    blx: float, bly: float, bl_radius: float,
    lcx: float, lcy: float,
    lax: float, lay: float, la_radius: float,
    dlx: float, dly: float, dl_c1x: float, dl_c1y: float, dl_c2x: float, dl_c2y: float,
    drx: float, dry: float, dr_c1x: float, dr_c1y: float, dr_c2x: float, dr_c2y: float,
    rax: float, ray: float, ra_radius: float,
    rcx: float, rcy: float,
    srx: float, sry: float, sr_radius: float,
    stem_sweep: bool,
    corner_sweep: bool,
}

export component SettingsWindow inherits Window {
    title: "Tree Settings";
    width: 320px;
    default-font-family: "Consolas";

    callback reset-tree();

    in-out property <float> node-activity-probability: 0.30;
    in-out property <float> branch-threshold: 50.0;
    in-out property <float> branch-elevation: 40.0;
    in-out property <float> branch-thickness-factor: 1.0;
    in-out property <float> branch-random-variation: 15.0;
    in-out property <float> growth-rate-length: 1.0;
    in-out property <float> auxin-production: 10.0;
    in-out property <float> auxin-threshold: 0.1;
    in-out property <float> auxin-consumption-rate: 0.05;
    in-out property <float> min-activation-age: 100;
    in-out property <float> gravitropism-threshold: 80.0;
    in-out property <float> gravitropism-rate: 0.1;
    in-out property <bool> paused: false;

    // Properties for seed
    in-out property <string> current-seed: "0"; // Read-only
    in-out property <string> pending-seed: ""; // Editable; applied on reset
    in-out property <string> seed-error: "";

    VerticalLayout {
        padding: 10px;
        spacing: 4px;

        Text { text: "Activity Prob: " + Math.round(root.node-activity-probability * 100) + "%"; }
        Slider { minimum: 0; maximum: 1; value <=> root.node-activity-probability; }

        Text { text: "Branch Threshold: " + Math.round(root.branch-threshold); }
        Slider { minimum: 10; maximum: 200; value <=> root.branch-threshold; }

        Text { text: "Branch Elevation: " + Math.round(root.branch-elevation) + "°"; }
        Slider { minimum: 5; maximum: 80; value <=> root.branch-elevation; }

        Text { text: "Thickness Factor: " + Math.round(root.branch-thickness-factor * 10) / 10; }
        Slider { minimum: 0.1; maximum: 5; value <=> root.branch-thickness-factor; }

        Text { text: "Random Variation: " + Math.round(root.branch-random-variation) + "°"; }
        Slider { minimum: 0; maximum: 45; value <=> root.branch-random-variation; }

        Text { text: "Growth Rate: " + Math.round(root.growth-rate-length * 10) / 10; }
        Slider { minimum: 0.1; maximum: 5; value <=> root.growth-rate-length; }

        Text { text: "Auxin Production: " + Math.round(root.auxin-production); }
        Slider { minimum: 0; maximum: 50; value <=> root.auxin-production; }

        Text { text: "Auxin Threshold: " + Math.round(root.auxin-threshold * 100) / 100; }
        Slider { minimum: 0; maximum: 5; value <=> root.auxin-threshold; }

        Text { text: "Auxin Consumption: " + Math.round(root.auxin-consumption-rate * 100) / 100; }
        Slider { minimum: 0; maximum: 1; value <=> root.auxin-consumption-rate; }

        Text { text: "Min Activation Age: " + Math.round(root.min-activation-age); }
        Slider { minimum: 0; maximum: 500; value <=> root.min-activation-age; }

        Text { text: "Gravitropism Threshold: " + Math.round(root.gravitropism-threshold) + "°"; }
        Slider { minimum: 0; maximum: 89; value <=> root.gravitropism-threshold; }

        Text { text: "Gravitropism Rate: " + Math.round(root.gravitropism-rate * 100) / 100; }
        Slider { minimum: 0; maximum: 1; value <=> root.gravitropism-rate; }

        Text {
            text: "Current Seed: " + root.current-seed;
            color: #888;
        }

        LineEdit {
            placeholder-text: "Leave empty for random";
            text <=> pending-seed;
        }

        // Error text for invalid seed
        if seed-error != "": Text {
            text: seed-error;
            color: red;
        }

        Button {
            text: root.paused ? "▶ Play" : "⏸ Pause";
            clicked => { root.paused = !root.paused; }
        }

        Button {
            text: "Reset Tree";
            clicked => { root.reset-tree(); }
        }
    }

    MenuBar {
        Menu{
            title: "Help";
            MenuItem{
                title: "About";
                activated => { about-popup.show(); }
            }
        }
    }

    about-popup := PopupWindow {
        x: 10px;
        y: 10px;
        width: 300px;
        AboutSlint {}
    }
}

export component AppWindow inherits Window {
    no-frame: true;
    background: transparent;

    in property <[SegmentData]> segments;
    for segment in segments : Path {
        width: 100%;
        height: 100%;
        viewbox-x: 0;
        viewbox-y: 0;
        viewbox-width: root.width / 1px;
        viewbox-height: root.height / 1px;
        fill: white;
        //fill-rule: evenodd;
        stroke: white;
        stroke-width: 1px;
        MoveTo {
            x: segment.x1;
            y: segment.y1;
        }
        LineTo {
            x: segment.x2;
            y: segment.y2;
        }
        LineTo {
            x: segment.x3;
            y: segment.y3;
        }
        ArcTo {
            x: segment.x4;
            y: segment.y4;
            radius-x: segment.radius;
            radius-y: segment.radius;
            sweep: segment.sweep;
        }
        Close{}
    }

    in property <[LeafData]> leaves;
    for leaf in leaves : Path {
        width: 100%;
        height: 100%;
        viewbox-x: 0;
        viewbox-y: 0;
        viewbox-width: root.width / 1px;
        viewbox-height: root.height / 1px;
        fill: green;
        stroke: darkgreen;
        stroke-width: 1px;
        // Petiole
        MoveTo { x: leaf.px; y: leaf.py; }
        LineTo { x: leaf.bx; y: leaf.by; }
        // stem to bottom left
        ArcTo { x: leaf.blx; y: leaf.bly; radius-x: leaf.bl-radius; radius-y: leaf.bl-radius; sweep: leaf.stem-sweep; }
        // bottom left to left curve
        LineTo { x: leaf.lcx; y: leaf.lcy; }
        // bottom left corner arc
        ArcTo { x: leaf.lax; y: leaf.lay; radius-x: leaf.la-radius; radius-y: leaf.la-radius; sweep: leaf.corner-sweep; }
        // divot left arc
        CubicTo { x: leaf.dlx; y: leaf.dly; control-1-x: leaf.dl-c1x; control-1-y: leaf.dl-c1y; control-2-x: leaf.dl-c2x; control-2-y: leaf.dl-c2y; }
        // divot right arc
        CubicTo { x: leaf.drx; y: leaf.dry; control-1-x: leaf.dr-c1x; control-1-y: leaf.dr-c1y; control-2-x: leaf.dr-c2x; control-2-y: leaf.dr-c2y; }
        // bottom right corner arc
        ArcTo { x: leaf.rax; y: leaf.ray; radius-x: leaf.ra-radius; radius-y: leaf.ra-radius; sweep: leaf.corner-sweep; }
        // bottom right to stem
        LineTo { x: leaf.rcx; y: leaf.rcy; }
        // stem to base
        ArcTo { x: leaf.srx; y: leaf.sry; radius-x: leaf.sr-radius; radius-y: leaf.sr-radius; sweep: leaf.stem-sweep; }
        Close {}
    }
}   